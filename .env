# ================================================================
# SocialConnect — Environment Variables Template
# ================================================================
# STEP 1: Copy this file → .env
#         cp .env.example .env
#
# STEP 2: Fill in every value marked with  ← YOUR VALUE HERE
#
# STEP 3: NEVER commit .env to Git.
#         It is already listed in .gitignore.
# ================================================================


# ----------------------------------------------------------------
# 1. SUPABASE — Database + Storage
#    Get these from: https://supabase.com → your project →
#    Project Settings → API
# ----------------------------------------------------------------

# Your Supabase project URL  (looks like https://xxxxxxxxxxxx.supabase.co)
SUPABASE_URL=htlpjjghpjojmdvldwtt.supabase.co
# Service Role key  (secret — never expose this in the browser)
# Found in: Project Settings → API → Project API keys → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imh0bHBqamdocGpvam1kdmxkd3R0Iiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NDQ5MjU4MSwiZXhwIjoyMDkwMDY4NTgxfQ.vqVCKmiiQ-4WrSBc84BLUfPfqkWLzEBotLBEB-WD1os
# Storage bucket name for images (create this in Supabase → Storage)
# Default value is "images" — only change if you named your bucket differently
SUPABASE_STORAGE_BUCKET=images


# ----------------------------------------------------------------
# 2. DATABASE — Supabase PostgreSQL connection string
#    Found in: Project Settings → Database → Connection string → URI
#    Replace [YOUR-PASSWORD] with your actual database password

DATABASE_URL=postgresql://postgres.htlpjjghpjojmdvldwtt:Nishanth%40.123@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres
# ----------------------------------------------------------------
# 3. JWT SECRET — signs authentication tokens
#    Must be a long random string — never share or commit this.
#    Generate one:
#      node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ----------------------------------------------------------------
SESSION_SECRET=2ae116b90fcf668b1c939bbc903b1bb99d332021cf3e746bad0b44d9f78ad132


# ----------------------------------------------------------------
# 4. PORT — API server port (optional)
PORT=8081
# ----------------------------------------------------------------
#    Leave as 8080 unless your host requires a different port.
#    On Replit this is set automatically, no need to change.
# ----------------------------------------------------------------
